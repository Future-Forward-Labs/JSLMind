# ─── Phase 1: Platform Foundation ──────────────────────────────────────────────
POSTGRES_PASSWORD=
REDIS_PASSWORD=
KEYCLOAK_ADMIN_PASSWORD=
GRAFANA_ADMIN_PASSWORD=          # Set before demo — default shown in README quickstart table

# ─── Phase 2: LLM Gateway ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=

# WARNING: Change sk-jsl-master before demo — anyone with this key controls all LLM spending
LITELLM_MASTER_KEY=sk-jsl-master

# ─── Phase 3: Agent Catalog ─────────────────────────────────────────────────────
DEMO_USER_PASSWORD=Demo123!      # Keycloak demo user — change before client-facing demo

# ─── Phase 4: Medallion Pipeline ────────────────────────────────────────────────
MINIO_ROOT_USER=jslmind
MINIO_ROOT_PASSWORD=
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# ─── Phase 5: OT/CBM Streaming ──────────────────────────────────────────────────
# (no extra vars — Temporal uses POSTGRES_PASSWORD above)

# ─── Phase 7: Agent Builder ─────────────────────────────────────────────────────
DIFY_SECRET_KEY=
N8N_ENCRYPTION_KEY=

# ─── Phase 8: Gateway + UI ──────────────────────────────────────────────────────
KONG_ADMIN_TOKEN=

# ─── AWS only ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
